generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StorePlatform {
  SHOPIFY
  WOOCOMMERCE
  API
}

enum ConnectionProvider {
  SHOPIFY
  WOOCOMMERCE
  META
  API
}

enum ProductCategory {
  SCALE
  TEST
  KILL
  RISK
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  /// $50/mo — 1 store, all features
  STARTER
  /// $100/mo — 5 stores, all features
  GROWTH
  /// $250/mo — unlimited stores + Advanced Analytics
  SCALE
  /// Legacy users signed up before plans existed — unlimited stores
  GRANDFATHERED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  role         UserRole      @default(USER)
  plan         UserPlan      @default(STARTER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  stores       Store[]
  resetTokens  PasswordResetToken[]
  settings     UserSettings?
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Automation rule toggles
  ruleScale         Boolean  @default(true)
  ruleTest          Boolean  @default(true)
  ruleKill          Boolean  @default(true)
  ruleInventory     Boolean  @default(true)
  // Score thresholds (0–100)
  thresholdScale    Int      @default(80)
  thresholdTest     Int      @default(50)
  thresholdKill     Int      @default(25)
  // Notification preferences
  notifEmailReports Boolean  @default(true)
  notifWhatsapp     Boolean  @default(false)
  notifWeeklyDigest Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Store {
  id             String        @id @default(cuid())
  name           String
  platform       StorePlatform
  storeUrl       String
  currency       String
  lastSyncAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ownerId        String
  owner          User          @relation(fields: [ownerId], references: [id])
  connections    Connection[]
  products       ProductMeta[]
  dailyMetrics   DailyMetric[]
  auditLogs      AuditLog[]
}

model Connection {
  id              String             @id @default(cuid())
  provider        ConnectionProvider
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  scopes          String?
  // Meta-specific: which ad account and catalog to sync for this store
  metaAdAccountId String?            // e.g. "act_123456789"
  metaCatalogId   String?            // e.g. "987654321"
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  storeId         String
  store           Store              @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
}

model ProductMeta {
  id         String          @id @default(cuid())
  externalId String
  sku        String?
  /// All variant / variation IDs for this product.
  /// Shopify: every variant ID. WooCommerce: every variation ID (in-stock + out-of-stock).
  /// Meta catalogs report spend at the variant level — this lets syncMeta map
  /// any variation ID back to its parent product for correct attribution.
  altIds     String[]        @default([])
  title      String
  imageUrl   String?
  productUrl String?
  score      Float
  category   ProductCategory
  updatedAt  DateTime        @updatedAt
  storeId    String
  store      Store           @relation(fields: [storeId], references: [id])
  dailyMetrics DailyMetric[]

  @@unique([storeId, externalId])
  @@index([storeId, score])
}

model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime
  roas            Float
  blendedRoas     Float?
  ctr             Float
  conversionRate  Float
  margin          Float
  velocity        Float
  spend           Float
  revenue         Float
  metaRevenue     Float?
  impressions     Int?
  clicks          Int?
  conversions     Int?
  inventoryLevel  Int?
  storeId         String
  productId       String
  product         ProductMeta @relation(fields: [productId], references: [id])
  store           Store       @relation(fields: [storeId], references: [id])

  @@unique([storeId, productId, date])
  @@index([storeId, date])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}
