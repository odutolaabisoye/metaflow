generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StorePlatform {
  SHOPIFY
  WOOCOMMERCE
  API
}

enum ConnectionProvider {
  SHOPIFY
  WOOCOMMERCE
  META
  API
}

enum ProductCategory {
  SCALE
  TEST
  KILL
  RISK
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  /// $50/mo — 1 store, all features
  STARTER
  /// $100/mo — 5 stores, all features
  GROWTH
  /// $250/mo — unlimited stores + Advanced Analytics
  SCALE
  /// Legacy users signed up before plans existed — unlimited stores
  GRANDFATHERED
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  passwordHash    String
  role            UserRole      @default(USER)
  plan            UserPlan      @default(STARTER)
  frozenAt        DateTime?
  trialEndsAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  stores          Store[]
  resetTokens     PasswordResetToken[]
  settings        UserSettings?
  sentInvites     TeamInvite[]  @relation("SentInvites")
  teamMemberships TeamMember[]  @relation("TeamMemberships")
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Automation rule toggles
  ruleScale         Boolean  @default(true)
  ruleTest          Boolean  @default(true)
  ruleKill          Boolean  @default(true)
  ruleInventory     Boolean  @default(true)
  // Score thresholds (0–100)
  thresholdScale    Int      @default(80)
  thresholdTest     Int      @default(50)
  thresholdKill     Int      @default(25)
  // Scoring benchmarks — "full marks" targets for each metric
  benchmarkRoas      Float    @default(5)     // ROAS = 5x → full 35pts
  benchmarkCtr       Float    @default(0.03)  // CTR = 3% → full 20pts
  benchmarkMargin    Float    @default(0.5)   // Margin = 50% → full 25pts
  benchmarkInventory Int      @default(10)    // ≥10 units → full 20pts
  // Notification preferences
  notifEmailReports Boolean  @default(true)
  notifWhatsapp     Boolean  @default(false)
  notifWeeklyDigest Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Store {
  id               String        @id @default(cuid())
  name             String
  platform         StorePlatform
  storeUrl         String
  currency         String
  timezone         String        @default("Africa/Lagos")  // IANA timezone, e.g. "America/New_York"
  lastSyncAt       DateTime?
  lastSyncStatus   String        @default("IDLE")  // IDLE | RUNNING | SUCCESS | ERROR
  lastSyncError    String?
  lastSyncProvider String?
  benchmarkRoas      Float?   // overrides UserSettings.benchmarkRoas for this store
  benchmarkCtr       Float?   // overrides UserSettings.benchmarkCtr for this store
  benchmarkMargin    Float?   // overrides UserSettings.benchmarkMargin for this store
  benchmarkInventory Int?     // overrides UserSettings.benchmarkInventory for this store
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ownerId          String
  owner          User          @relation(fields: [ownerId], references: [id])
  connections    Connection[]
  products       ProductMeta[]
  dailyMetrics   DailyMetric[]
  auditLogs      AuditLog[]
  teamInvites    TeamInvite[]
  teamMembers    TeamMember[]
  scoreHistory   ProductScoreHistory[]
}

model Connection {
  id              String             @id @default(cuid())
  provider        ConnectionProvider
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  scopes          String?
  // Meta-specific: which ad account and catalog to sync for this store
  metaAdAccountId String?            // e.g. "act_123456789"
  metaCatalogId   String?            // e.g. "987654321"
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  storeId         String
  store           Store              @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
}

model ProductMeta {
  id         String          @id @default(cuid())
  externalId String
  sku        String?
  /// All variant / variation IDs for this product.
  /// Shopify: every variant ID. WooCommerce: every variation ID (in-stock + out-of-stock).
  /// Meta catalogs report spend at the variant level — this lets syncMeta map
  /// any variation ID back to its parent product for correct attribution.
  altIds     String[]        @default([])
  title      String
  imageUrl   String?
  productUrl String?
  score      Float
  category   ProductCategory
  updatedAt  DateTime        @updatedAt
  storeId    String
  store      Store           @relation(fields: [storeId], references: [id])
  dailyMetrics DailyMetric[]
  scoreHistory ProductScoreHistory[]

  /// Pre-computed 30-day aggregates — written by the scoring job after every sync.
  /// Avoids per-request DailyMetric aggregation queries on the products page.
  spend30d       Float    @default(0)
  revenue30d     Float    @default(0)
  metaRevenue30d Float    @default(0)
  impressions30d Int      @default(0)
  clicks30d      Int      @default(0)
  conversions30d Int      @default(0)
  roas30d        Float    @default(0)
  ctr30d         Float    @default(0)
  addToCart30d              Int   @default(0)
  addToCartOmni30d          Int   @default(0)
  checkoutInitiated30d      Int   @default(0)
  checkoutInitiatedOmni30d  Int   @default(0)

  /// Pre-computed 7-day aggregates — written by the scoring job after every sync.
  spend7d        Float    @default(0)
  revenue7d      Float    @default(0)
  metaRevenue7d  Float    @default(0)
  impressions7d  Int      @default(0)
  clicks7d       Int      @default(0)
  conversions7d  Int      @default(0)
  roas7d         Float    @default(0)
  ctr7d          Float    @default(0)
  addToCart7d              Int   @default(0)
  addToCartOmni7d          Int   @default(0)
  checkoutInitiated7d      Int   @default(0)
  checkoutInitiatedOmni7d  Int   @default(0)

  margin         Float    @default(0.35)
  inventoryLevel Float?
  metricsComputedAt DateTime?

  @@unique([storeId, externalId])
  @@index([storeId, score])
  @@index([storeId, spend30d])
  @@index([storeId, roas30d])
  @@index([storeId, impressions30d])
  @@index([storeId, addToCartOmni30d])
  @@index([storeId, spend7d])
  @@index([storeId, roas7d])
  @@index([storeId, impressions7d])
  @@index([storeId, addToCartOmni7d])
}

model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime
  roas            Float
  blendedRoas     Float?
  ctr             Float
  conversionRate  Float
  margin          Float
  velocity        Float
  spend           Float
  revenue         Float
  metaRevenue     Float?
  impressions     Int?
  clicks          Int?
  conversions     Int?
  inventoryLevel  Int?
  addToCart              Int?   // onsite (pixel) add_to_cart events
  addToCartOmni          Int?   // omni_add_to_cart — all channels combined
  checkoutInitiated      Int?   // onsite initiated_checkout events
  checkoutInitiatedOmni  Int?   // omni_initiated_checkout — all channels combined
  storeId         String
  productId       String
  product         ProductMeta @relation(fields: [productId], references: [id])
  store           Store       @relation(fields: [storeId], references: [id])

  @@unique([storeId, productId, date])
  @@index([storeId, date])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model ProductScoreHistory {
  id         String          @id @default(cuid())
  productId  String
  product    ProductMeta     @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId    String
  store      Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  score      Float
  category   ProductCategory
  date       DateTime        @default(now())

  @@unique([productId, date])
  @@index([productId, date])
}

model TeamInvite {
  id         String    @id @default(cuid())
  email      String
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invitedBy  String
  inviter    User      @relation("SentInvites", fields: [invitedBy], references: [id])
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([storeId])
  @@index([email])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  storeId  String
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  role     String   @default("VIEWER") // VIEWER | EDITOR
  joinedAt DateTime @default(now())

  @@unique([userId, storeId])
  @@index([storeId])
}
