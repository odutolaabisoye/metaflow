# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metaflow?schema=public

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin (Nuxt dev server)
CORS_ORIGIN=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
CSRF_SECRET=change_me_generate_with_openssl_rand_hex_32

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used by BullMQ for job queues
REDIS_URL=redis://localhost:6379

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
# For password reset emails. Use SendGrid, Resend, Postmark, etc.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=no-reply@metaflow.app

# ─── App URL ──────────────────────────────────────────────────────────────────
# Public URL of this API server (used for OAuth redirect URIs)
# In production: https://api.metaflow.app
APP_URL=http://localhost:4000

# ─── Meta / Facebook ──────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Settings → Basic
# Required for Meta Ads OAuth and Marketing API sync
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ─── Shopify App ──────────────────────────────────────────────────────────────
# Get from: https://partners.shopify.com → Apps → Your App → API credentials
#
# In the Shopify Partner Dashboard set:
#   App URL:                  {APP_URL}/shopify/install
#   Allowed redirect URL:     {APP_URL}/shopify/callback
#
# The Shopify app handles installation only — all data management is on the
# MetaFlow dashboard. Merchants are redirected there after OAuth completes.
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
# STRIPE_WEBHOOK_SECRET: from Stripe CLI `stripe listen` or Dashboard → Webhooks
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# ─── Token Encryption ─────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens stored in the database.
# Generate with: openssl rand -hex 32   (must be exactly 64 hex characters)
ENCRYPTION_KEY=change_me_64_hex_chars_generate_with_openssl_rand_hex_32

# HMAC secret for signing OAuth state parameters (Meta OAuth CSRF protection).
# Falls back to CSRF_SECRET if not set — set explicitly in production.
# Generate with: openssl rand -hex 32
STATE_SECRET=change_me_generate_with_openssl_rand_hex_32

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Error monitoring. Get DSN from: https://sentry.io → Your Project → Settings → SDK Setup
# Leave empty to disable.
SENTRY_DSN=
SENTRY_RELEASE=
